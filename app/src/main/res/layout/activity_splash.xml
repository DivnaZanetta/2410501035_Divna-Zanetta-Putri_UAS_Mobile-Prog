<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_splash_soft">

    <FrameLayout
        android:layout_width="160dp"
        android:layout_height="160dp">

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/logow"
            android:contentDescription="Logo EndemikDB"/>

    </FrameLayout>

    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Flora Fauna"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#1B5E20"
        android:layout_marginTop="20dp"
        android:letterSpacing="0.05"/>

    <!-- SUBTITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Flora &amp; Fauna"
        android:textSize="13sp"
        android:textColor="#2E7D32"
        android:layout_marginTop="6dp"/>

    <LinearLayout
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:background="#A5D6A7"
        android:layout_marginTop="20dp"/>

    <!-- NAME -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Divna Zanetta Putri"
        android:textSize="13sp"
        android:textColor="#1B5E20"
        android:textStyle="bold"
        android:layout_marginTop="20dp"/>

    <!-- NIM -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2410501035"
        android:textSize="11sp"
        android:textColor="#4E5D4E"
        android:layout_marginTop="2dp"/>

    <!-- PRODI -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="D3 Sistem Informasi"
        android:textSize="11sp"
        android:textColor="#4E5D4E"
        android:layout_marginTop="2dp"/>

    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:indeterminateTint="#2E7D32"/>

    <!-- VERSION -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="10sp"
        android:textColor="#6B6B6B"
        android:layout_marginTop="12dp"/>

</LinearLayout>